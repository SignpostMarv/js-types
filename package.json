{
  "type": "module",
  "name": "@signpostmarv/json-schema-typescript-codegen",
  "description": "JSON Schema TypeScript CodeGen",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SignpostMarv/JSON-Schema-TypeScript-CodeGen.git"
  },
  "funding": "https://github.com/SignpostMarv/JSON-Schema-TypeScript-CodeGen?sponsor=1",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./ajv": {
      "types": "./src/Ajv/index.d.ts",
      "default": "./src/Ajv/index.js"
    },
    "./javascript-overrides": {
      "types": "./src/javascript/types.d.ts",
      "default": "./src/javascript/types.js"
    },
    "./typescript-overrides": {
      "types": "./src/typescript/index.d.ts",
      "default": "./src/typescript/index.js"
    }
  },
  "engines": {
    "node": "^25.0"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "src/**/*.js",
    "src/**/*.d.ts"
  ],
  "devDependencies": {
    "@satisfactory-dev/custom-assert": "^0.2.5",
    "@signpostmarv/oxlint-config": "^0.3.1",
    "@signpostmarv/ts-assert": "^0.4.1",
    "@stylistic/eslint-plugin": "^5.9.0",
    "@types/node": "^25.6.0",
    "@types/regexp.escape": "^2.0.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "prettier": "^3.8.2"
  },
  "peerDependencies": {
    "@satisfactory-dev/predicates.ts": "^0.3.0",
    "ajv": "^8.18.0",
    "typescript": "~5.9.3"
  }
}
